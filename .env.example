# ── DATABASE ──────────────────────────────────────────
DATABASE_URL="postgresql://papertrading:password@localhost:5432/papertrading"
REDIS_URL="redis://:redispass@localhost:6379"

# ── AUTH ──────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-256-bit-secret"
JWT_REFRESH_SECRET="change-this-to-another-random-secret"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── NEXT.JS ───────────────────────────────────────────
NEXTAUTH_SECRET="change-this-too"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"

# ── MARKET DATA APIs ──────────────────────────────────
POLYGON_API_KEY="your_polygon_key_here"
ALPHA_VANTAGE_KEY="your_alpha_vantage_key"
FINNHUB_API_KEY="your_finnhub_key"

# ── EMAIL (Resend) ────────────────────────────────────
RESEND_API_KEY="your_resend_key"
EMAIL_FROM="noreply@yourapp.com"

# ── APP CONFIG ────────────────────────────────────────
STARTING_CAPITAL="100000"
PORT="4000"
NODE_ENV="development"
